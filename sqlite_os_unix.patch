+
+/*
+** Inferno file I/O wrappers.
+**
+** These map SQLite's unix VFS syscalls to libopen/libread/libwrite/libclose
+** as provided by Inferno's emu/port/discall.c.
+*/
+extern int libopen(char *name, int omode);
+extern int libread(int fd, void *buf, int n);
+extern int libwrite(int fd, void *buf, int n);
+extern int libclose(int fd);
+
+static int infernoOpen(const char *zFile, int flags, int mode){
+  int omode = 0;
+  UNUSED_PARAMETER(mode);
+  switch( flags & O_ACCMODE ){
+    case O_WRONLY: omode = OWRITE; break;
+    case O_RDWR:   omode = ORDWR;  break;
+    case O_RDONLY:
+    default:       omode = OREAD;  break;
+  }
+#ifdef O_TRUNC
+  if( flags & O_TRUNC )   omode |= OTRUNC;
+#endif
+#ifdef O_CLOEXEC
+  if( flags & O_CLOEXEC ) omode |= OCEXEC;
+#endif
+#ifdef O_EXCL
+  if( flags & O_EXCL )    omode |= OEXCL;
+#endif
+  /* Inferno open(2) does not create files; ignore O_CREAT here. */
+  return libopen((char *)zFile, omode);
+}
+
+static ssize_t infernoRead(int fd, void *buf, size_t n){
+  if( n>INT_MAX ) n = INT_MAX;
+  return (ssize_t)libread(fd, buf, (int)n);
+}
+
+static ssize_t infernoWrite(int fd, const void *buf, size_t n){
+  if( n>INT_MAX ) n = INT_MAX;
+  return (ssize_t)libwrite(fd, (void *)buf, (int)n);
+}
+
+static int infernoClose(int fd){
+  return libclose(fd);
+}
+#endif
